# Sunbird DCIM MCP Server Configuration
# Copy this file to .env and update values as needed

# =============================================================================
# Server Configuration
# =============================================================================
MCP_PORT=8080
MCP_HOST=0.0.0.0
MCP_SERVER_NAME=sunbird-dcim-mcp
MCP_VERSION=1.0.0

# =============================================================================
# Sunbird DCIM Connection
# =============================================================================
# Base URL for both dcTrack and Power IQ (typically same server)
SUNBIRD_BASE_URL=https://192.168.200.201

# API credentials
SUNBIRD_USERNAME=API
SUNBIRD_PASSWORD=your-password-here

# Request timeout in milliseconds
SUNBIRD_TIMEOUT=30000

# Set to true if using valid SSL certificates
# Set to false for self-signed certificates (development)
SUNBIRD_REJECT_UNAUTHORIZED=false

# =============================================================================
# Caching Configuration
# =============================================================================
# Enable response caching
CACHE_ENABLED=true

# Cache TTL in seconds (how long to cache API responses)
CACHE_TTL_SECONDS=60

# =============================================================================
# Logging Configuration
# =============================================================================
# Log level: debug, info, warn, error
LOG_LEVEL=info

# =============================================================================
# Node.js Configuration
# =============================================================================
NODE_ENV=development
