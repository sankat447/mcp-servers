# Credentials & Secrets — NEVER commit these
# =============================================================================

# Environment files with real credentials
.env
.env.local
.env.*.local
.env.production
.env.staging

# Deployment files containing hardcoded credentials
deploy/openshift/deployment.yaml
deploy/docker/docker-compose.yml

# Kubernetes / OpenShift secrets
*-secret.yaml
*-secrets.yaml
secret*.yaml
secrets*.yaml

# TLS / SSL certificates and keys
*.pem
*.key
*.crt
*.cert
*.p12
*.pfx
*.jks
*.keystore
*.truststore

# SSH keys
id_rsa
id_ed25519
*.pub

# Token / credential files
*.token
*.credentials
credentials.json
service-account.json
kubeconfig
.kube/

